# Copy to .env.local and fill in. .env.local is gitignored.

# ── Browser (Vite) ──────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key...

# ── Server-side only (Vercel API routes / cron) ─────────────────
# These should ALSO be set in Vercel → Settings → Environment Variables.
# DO NOT prefix with VITE_; they must not reach the browser.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...
RESEND_API_KEY=re_...your-resend-key...
REMINDER_FROM=Got Schooled <onboarding@resend.dev>
